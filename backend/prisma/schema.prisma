generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Apartment {
  id          String   @id @default(uuid())
  name        String
  unitNumber  String
  project     String
  city        String
  description String
  address     String
  area        Float
  price       Float
  beds        Int
  baths       Int
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
